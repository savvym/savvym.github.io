---
import { render } from "astro:content";
import type { BlogPost } from "../lib/posts";
import {
  excerptFromMarkdown,
  formatDate,
  getTagPath,
  readingTime,
  shouldRenderRichExcerpt
} from "../lib/posts";
import { withBase } from "../lib/site";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const excerpt = excerptFromMarkdown(post.body);
const richExcerpt = shouldRenderRichExcerpt(post.body);
const renderedPost = richExcerpt ? await render(post) : null;
const RichExcerpt = renderedPost?.Content;
---

<article class="post-preview" data-post-slug={post.slug}>
  <div class="post-meta">
    <span class="post-date">{formatDate(post.data.pubDate)}</span>
        <span class="post-reading-time">{readingTime(post.body)} min read</span>
        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={withBase(getTagPath(tag))}>
              {tag}
            </a>
          ))}
    </div>
  </div>
  <h2 class="post-title">
    <a href={withBase(`/blog/${post.slug}/`)}>{post.data.title}</a>
  </h2>
  {RichExcerpt ? (
    <div class="post-excerpt rich-excerpt">
      <RichExcerpt />
    </div>
  ) : (
    <p class="post-excerpt truncated">{excerpt}</p>
  )}
  <div class="post-read-more">
    <a href={withBase(`/blog/${post.slug}/`)}>Read more →</a>
  </div>
</article>
