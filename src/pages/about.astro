---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_GITHUB,
  SITE_LEETCODE,
  SITE_LINKEDIN,
  SITE_TITLE
} from "../lib/site";
---

<BaseLayout title={`About - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <div class="section-label">
    <span>/</span>
    About
  </div>
  <div class="about-copy">
    <h1>About</h1>
    <p>
      Hi, I'm {SITE_AUTHOR}. I write about algorithms, programming languages,
      Linux, and paper notes on this blog.
    </p>
    <p>
      This site keeps the content from my older blog, rebuilt into the current
      design and Markdown workflow.
    </p>
    <div class="profile-card">
      <div class="profile-card-label">Coding Profile</div>
      <div class="profile-card-header">
        <div>
          <h2>LeetCode</h2>
          <p class="profile-card-handle">@savvym</p>
        </div>
        <div class="profile-card-mark" aria-hidden="true">LC</div>
      </div>
      <p>
        I use LeetCode CN for algorithm practice and problem-solving notes.
        Some of the algorithm posts on this blog come from that workflow.
      </p>
      <p class="profile-card-actions">
        <a href={SITE_LEETCODE} target="_blank" rel="noreferrer">Open LeetCode Profile</a>
      </p>
    </div>
    <p class="about-links">
      <a href={SITE_LEETCODE} target="_blank" rel="noreferrer">LeetCode</a>
      {" · "}
      <a href={SITE_GITHUB} target="_blank" rel="noreferrer">GitHub</a>
      {SITE_LINKEDIN && (
        <>
          {" · "}
          <a href={SITE_LINKEDIN} target="_blank" rel="noreferrer">LinkedIn</a>
        </>
      )}
    </p>
  </div>
</BaseLayout>
