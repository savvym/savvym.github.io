---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { sortPosts } from "../lib/posts";
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from "../lib/site";

const posts = sortPosts(await getCollection("blog"));
const searchIndex = posts.map((post) => ({
  slug: post.slug,
  title: post.data.title,
  tags: post.data.tags.join(" "),
  body: post.body
}));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="search-box">
    <label class="sr-only" for="post-search">Search posts</label>
    <input id="post-search" type="search" placeholder="Search posts" autocomplete="off" />
    <div class="post-count"><span id="post-count">{posts.length}</span> of {posts.length}</div>
    <div class="match-info" id="search-status">Showing all posts</div>
  </div>

  <div class="section-label">
    <span>/</span>
    Recent Posts
  </div>

  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex)} />

  <div class="post-list" id="home-post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  <p class="post-read-more">
    <a href={withBase("/blog/")}>All posts →</a>
  </p>

  <script is:inline>
    (() => {
      const input = document.getElementById("post-search");
      const counter = document.getElementById("post-count");
      const status = document.getElementById("search-status");
      const cards = [...document.querySelectorAll("[data-post-slug]")];
      const raw = document.getElementById("search-index");

      if (!input || !counter || !status || !raw) {
        return;
      }

      const index = JSON.parse(raw.textContent ?? "[]");
      const total = index.length;

      const update = () => {
        const query = input.value.trim().toLowerCase();

        if (!query) {
          cards.forEach((card) => {
            card.style.display = "";
          });
          counter.textContent = String(total);
          status.textContent = "Showing all posts";
          return;
        }

        let matches = 0;

        for (const entry of index) {
          const haystack = `${entry.title} ${entry.tags} ${entry.body}`.toLowerCase();
          const card = document.querySelector(`[data-post-slug="${entry.slug}"]`);
          if (!card) {
            continue;
          }

          const visible = haystack.includes(query);
          card.style.display = visible ? "" : "none";
          if (visible) {
            matches += 1;
          }
        }

        counter.textContent = String(matches);
        status.textContent = matches
          ? `Found ${matches} matching post${matches === 1 ? "" : "s"}`
          : "No posts matched your search";
      };

      input.addEventListener("input", update);
    })();
  </script>
</BaseLayout>
